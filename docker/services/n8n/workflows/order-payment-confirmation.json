    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\n\nconst date = new Date(body.paidAt);\nconst paidAtFormatted = date.toLocaleDateString('es-PE', {\n  day: '2-digit',\n  month: 'long',\n  year: 'numeric',\n  hour: '2-digit',\n  minute: '2-digit'\n});\n\nconst itemsHtml = body.items.map(item => `\n  <tr>\n    <td style=\"padding:8px 0;border-bottom:1px solid #f1f5f9;color:#0f172a;font-size:13px;\">x${item.quantity}</td>\n    <td style=\"padding:8px 0;border-bottom:1px solid #f1f5f9;color:#64748b;font-size:13px;\">${body.currency} ${Number(item.unitPrice).toFixed(2)}</td>\n    <td style=\"padding:8px 0;border-bottom:1px solid #f1f5f9;color:#0f172a;font-weight:600;font-size:13px;text-align:right;\">${body.currency} ${Number(item.subtotal).toFixed(2)}</td>\n  </tr>\n`).join('');\n\nconst total = Number(body.total);\nconst subtotal = (total / 1.18);\nconst igv = total - subtotal;\n\nreturn [{\n  json: {\n    orderId: body.orderId,\n    mpPaymentId: body.mpPaymentId,\n    paymentStatus: body.paymentStatus,\n    paidAtFormatted,\n    email: body.email,\n    customerName: body.customerName ?? 'Cliente',\n    subtotal: subtotal.toFixed(2),\n    igv: igv.toFixed(2),\n    total: total.toFixed(2),\n    currency: body.currency,\n    itemsHtml\n  }\n}];"
      },
